% A slightly off-black for body text (borrowed from Metropolis)
\definecolor{mDarkTeal}{HTML}{23373b}

%%%%%%%%%%%%%%%%%%%%%%%%%% Implement the colour scheme

\setbeamercolor{title}{fg=TrinityBlue}
\setbeamercolor{subtitle}{fg=CoolGrey}
\setbeamercolor{frametitle}{fg=TrinityBlue}
\setbeamercolor{structure}{fg=TrinityBlue}

% Slightly off-white canvas, off-black text
\setbeamercolor{normal text}{fg=mDarkTeal, bg=black!2}
\setbeamercolor{background canvas}{bg=black!2}

% Table of contents
\setbeamercolor{section in toc}{fg=mDarkTeal}
\setbeamercolor{section in toc shaded}{fg=TrinityBlue}

% Bullet points
\setbeamertemplate{itemize items}[circle]
\setbeamercolor{item}{fg=TrinityBlue}
\setbeamercolor{subitem}{fg=CoolGrey}
\setbeamercolor{subsubitem}{fg=black!2}

% Hyperlinks
\setbeamercolor{links}{fg=pms_512}
\AtBeginDocument{%
  \hypersetup{colorlinks=true, citecolor=pms_512, linkcolor=TrinityBlue, urlcolor=pms_512}%
  % Patch \href so caption/figure environments can't override the link colour
  \let\collegegreen@oldhref\href
  \renewcommand{\href}[2]{\collegegreen@oldhref{#1}{\textcolor{pms_512}{#2}}}%
  % Natbib places \NAT@open ( inside the hyperlink group but \NAT@close )
  % outside it, so citecolor bleeds onto ( but not ). Fix: force both
  % delimiters to body text colour so they are never affected by citecolor.
  \@ifpackageloaded{natbib}{%
    \let\NAT@open@cg\NAT@open
    \let\NAT@close@cg\NAT@close
    \def\NAT@open{\textcolor{mDarkTeal}{\NAT@open@cg}}%
    \def\NAT@close{\textcolor{mDarkTeal}{\NAT@close@cg}}%
  }{}%
}

% Blocks / theorems / alerts
\setbeamertemplate{blocks}[rounded][shadow=true]
\setbeamercolor{alerted text}{fg=TrinityBlue}
\setbeamerfont{block title}{size=\Large}
\setbeamercolor{block title}{use=structure, fg=white, bg=TrinityBlue}
\setbeamercolor{block body}{use=structure, fg=mDarkTeal, bg=white}

% Give footnotes a little breathing room above the footer
\addtobeamertemplate{footnote}{}{\vspace{2ex}}

% Title page layout
\setbeamertemplate{title page}{%
  \begin{center}
    \vspace{0.5\baselineskip}
    \includegraphics[width=0.45\textwidth]{Trinity-Main-Logo.pdf}

    \vspace{0.75\baselineskip}
    {\Large\textbf{\textcolor{TrinityBlue}{\inserttitle}}}

    \vspace{0.25\baselineskip}
    {\normalsize\textcolor{CoolGrey}{\insertsubtitle}}

    \vspace{0.75\baselineskip}
    {\large \insertauthor}

    \vspace{0.25\baselineskip}
    {\small \insertinstitute}

    \vspace{0.25\baselineskip}
    \insertdate
  \end{center}
}

% Footer: TrinityBlue bar with institution name and frame number
\setbeamercolor{footlinecolor}{fg=white, bg=TrinityBlue}
\defbeamertemplate*{footline}{collegegreen}{%
  \ifthenelse{\boolean{metropolis@standout}}{}{% hide footer on standout slides
    \begin{beamercolorbox}[ht=4ex, leftskip=1.4cm, rightskip=0.3cm]{footlinecolor}
      \usebeamercolor{footlinecolor}%
      \vspace{0.1cm}
      \textbf{Trinity College Dublin}, the University of Dublin
      \hfill \insertframenumber
    \end{beamercolorbox}%
  }%
}

% "Standout" frame style — full-bleed TrinityBlue background with white text
% Usage: \begin{frame}[standout] ... \end{frame}
\providebool{metropolis@standout}
\define@key{beamerframe}{standout}[true]{%
  \booltrue{metropolis@standout}
  \begingroup
    \setkeys{beamerframe}{c}
    \setkeys{beamerframe}{noframenumbering}
    \setbeamercolor{background canvas}{bg=TrinityBlue}
    \setbeamercolor{normal text}{fg=white}
    \usebeamercolor[fg]{normal text}
    \color{white}
    \huge
    \centering
}
\apptocmd{\beamer@reseteecodes}{%
  \ifbool{metropolis@standout}{%
    \endgroup
    \boolfalse{metropolis@standout}
  }{}%
}{}{}

\mode<all>